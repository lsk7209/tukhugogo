# Vercel
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=replace-me
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=replace-me

# Turso, when replacing demo data.js with live data
TURSO_DATABASE_URL=libsql://your-db-org.turso.io
TURSO_AUTH_TOKEN=replace-me

# Data mode
# Use live in production. Set ALLOW_DEMO_DATA=true only for local/demo builds without Turso.
PATENT_DATA_MODE=live
ALLOW_DEMO_DATA=false

# Optional data provenance labels shown in UI/API responses
PATENT_DATA_SOURCE="특허청 KIPRIS · data.go.kr"
PATENT_DATA_AS_OF=2025-12-31
